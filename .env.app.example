# =============================================================================
# app-agenda — variáveis de ambiente
# Copie este arquivo para .env (local) ou use como base para o secret APP_ENV
# do GitHub Actions.
# O arquivo .env NÃO deve ser commitado (já está no .gitignore).
# =============================================================================

SERVER_PORT=8011

# PostgreSQL
DB_URL=jdbc:postgresql://postgres:5432/app_agenda
DB_USER=postgres
DB_PASSWORD=TROQUE_PELA_SENHA_REAL

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=TROQUE_PELA_SENHA_REAL

# MinIO
# URL interna da rede Docker (usada pelo backend para upload/download)
MINIO_URL=http://minio:9000
# URL pública acessível pelo browser (usada para gerar as presigned URLs)
# Local: http://localhost:9000  |  Produção: https://s3.dev2b.tec.br
MINIO_PUBLIC_URL=https://s3.dev2b.tec.br
MINIO_ACCESS_KEY=TROQUE_PELO_ACCESS_KEY_REAL
MINIO_SECRET_KEY=TROQUE_PELO_SECRET_KEY_REAL
MINIO_BUCKET_FOTOS=fotos
MINIO_BUCKET_DOCUMENTOS=documentos
